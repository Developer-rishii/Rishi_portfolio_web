<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Assistant</title>
</head>
<style>
    /* Premium AI Chat Interface Styling */
    .ai-chat-container {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.07), 0 5px 15px rgba(0, 0, 0, 0.03);
        margin-top: 3rem;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    
    .ai-chat-header {
        display: flex;
        align-items: center;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        padding-bottom: 1rem;
    }
    
    .ai-icon {
        width: 55px;
        height: 55px;
        background: linear-gradient(135deg, #FF7A3D, #ff9e71);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 1.2rem;
        color: white;
        font-size: 1.6rem;
        box-shadow: 0 5px 15px rgba(255, 122, 61, 0.3);
        animation: pulseIcon 3s infinite ease-in-out;
    }

    @keyframes pulseIcon {
        0%, 100% { transform: scale(1); box-shadow: 0 5px 15px rgba(255, 122, 61, 0.3); }
        50% { transform: scale(1.04); box-shadow: 0 5px 22px rgba(255, 122, 61, 0.55); }
    }
    
    .ai-chat-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #2c3e50;
        margin: 0;
    }

    .ai-chat-subtitle {
        font-size: 0.85rem;
        color: #7f8c8d;
        margin: 2px 0 0 0;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .ai-status-indicator {
        width: 8px;
        height: 8px;
        background-color: #2ecc71;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 8px #2ecc71;
        animation: blinkStatus 2s infinite ease-in-out;
    }

    @keyframes blinkStatus {
        0%, 100% { opacity: 0.6; }
        50% { opacity: 1; }
    }
    
    .ai-chat-messages {
        height: 380px;
        overflow-y: auto;
        margin-bottom: 1rem;
        padding: 1.2rem;
        background-color: rgba(245, 246, 250, 0.8);
        border-radius: 15px;
        border: 1px solid rgba(0, 0, 0, 0.02);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        scroll-behavior: smooth;
    }

    /* Custom Scrollbar for Chat Messages */
    .ai-chat-messages::-webkit-scrollbar {
        width: 6px;
    }
    .ai-chat-messages::-webkit-scrollbar-track {
        background: transparent;
    }
    .ai-chat-messages::-webkit-scrollbar-thumb {
        background: rgba(0, 0, 0, 0.1);
        border-radius: 10px;
    }
    .ai-chat-messages::-webkit-scrollbar-thumb:hover {
        background: rgba(0, 0, 0, 0.2);
    }
    
    .ai-message {
        padding: 0.85rem 1.2rem;
        border-radius: 16px;
        max-width: 80%;
        line-height: 1.5;
        font-size: 0.95rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        animation: slideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        position: relative;
    }

    @keyframes slideIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .ai-message.user {
        background: linear-gradient(135deg, #FF7A3D, #ff925f);
        color: white;
        margin-left: auto;
        border-bottom-right-radius: 2px;
        box-shadow: 0 4px 12px rgba(255, 122, 61, 0.2);
    }
    
    .ai-message.bot {
        background-color: white;
        color: #2c3e50;
        margin-right: auto;
        border-bottom-left-radius: 2px;
        border: 1px solid rgba(0, 0, 0, 0.04);
    }

    .ai-message.error-msg {
        background-color: #fde8e7;
        color: #c0392b;
        border: 1px solid #f5c2c2;
        margin-right: auto;
        border-bottom-left-radius: 2px;
    }
    
    /* Suggested Prompt Pills */
    .ai-suggestions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-bottom: 1.5rem;
        padding: 0 0.2rem;
    }

    .ai-pill {
        background-color: white;
        border: 1px solid rgba(255, 122, 61, 0.3);
        color: #FF7A3D;
        padding: 0.45rem 1.1rem;
        border-radius: 50px;
        font-size: 0.82rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.02);
    }

    .ai-pill:hover {
        background-color: #FF7A3D;
        color: white;
        border-color: #FF7A3D;
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(255, 122, 61, 0.2);
    }

    .ai-pill:active {
        transform: translateY(0);
    }
    
    .ai-chat-input-container {
        display: flex;
        gap: 0.8rem;
        position: relative;
        background-color: white;
        border: 1px solid rgba(0, 0, 0, 0.1);
        padding: 0.4rem;
        border-radius: 50px;
        transition: all 0.3s ease;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
    }

    .ai-chat-input-container:focus-within {
        border-color: #FF7A3D;
        box-shadow: 0 0 0 3px rgba(255, 122, 61, 0.15), 0 5px 15px rgba(0,0,0,0.03);
    }
    
    .ai-chat-input-container input {
        flex: 1;
        padding: 0.6rem 1.2rem;
        border: none;
        outline: none;
        font-size: 1rem;
        background: transparent;
        color: #2c3e50;
    }
    
    .ai-chat-input-container button {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #FF7A3D, #ff925f);
        color: white;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        box-shadow: 0 3px 8px rgba(255, 122, 61, 0.25);
    }
    
    .ai-chat-input-container button:hover {
        transform: scale(1.05);
        box-shadow: 0 5px 15px rgba(255, 122, 61, 0.4);
    }

    .ai-chat-input-container button:disabled {
        background: #ccc;
        box-shadow: none;
        cursor: not-allowed;
    }

    /* Typing Dots Animation */
    .typing-indicator {
        display: flex;
        gap: 5px;
        padding: 0.9rem 1.3rem;
        background-color: white;
        border-radius: 16px;
        border-bottom-left-radius: 2px;
        width: fit-content;
        align-items: center;
        margin-right: auto;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        border: 1px solid rgba(0, 0, 0, 0.04);
        animation: slideIn 0.2s ease-out forwards;
    }
    
    .typing-indicator span {
        width: 7px;
        height: 7px;
        background: #FF7A3D;
        border-radius: 50%;
        display: inline-block;
        animation: typing 1.4s infinite ease-in-out both;
    }
    
    .typing-indicator span:nth-child(1) { animation-delay: -0.32s; }
    .typing-indicator span:nth-child(2) { animation-delay: -0.16s; }
    
    @keyframes typing {
        0%, 80%, 100% { transform: scale(0.3); opacity: 0.4; }
        40% { transform: scale(1); opacity: 1; }
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {
        .ai-chat-container {
            padding: 1.2rem;
            margin-top: 1.5rem;
            border-radius: 15px;
        }

        .ai-icon {
            width: 45px;
            height: 45px;
            font-size: 1.3rem;
            margin-right: 0.8rem;
        }

        .ai-chat-title {
            font-size: 1.3rem;
        }

        .ai-chat-messages {
            height: 320px;
            padding: 0.8rem;
            gap: 0.8rem;
        }

        .ai-message {
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            max-width: 90%;
        }

        .ai-suggestions {
            gap: 0.4rem;
            margin-bottom: 1rem;
        }

        .ai-pill {
            padding: 0.35rem 0.8rem;
            font-size: 0.75rem;
        }

        .ai-chat-input-container {
            padding: 0.2rem;
        }

        .ai-chat-input-container input {
            padding: 0.5rem 0.8rem;
            font-size: 0.9rem;
        }

        .ai-chat-input-container button {
            width: 40px;
            height: 40px;
        }
    }
</style>
<body>
    <!-- AI Chat Integration -->
    <section class="section" id="ai">
        <div class="section-title">
            <h2>AI Portfolio Assistant</h2>
            <p>Engage with my genuine conversational AI agent to discover my software background, engineering capabilities, and design offerings.</p>
        </div>
        <div class="ai-chat-container fade-in">
            <div class="ai-chat-header">
                <div class="ai-icon">
                    <i class="fas fa-robot"></i>
                </div>
                <div>
                    <h3 class="ai-chat-title">Rishi's Assistant</h3>
                    <p class="ai-chat-subtitle">
                        <span class="ai-status-indicator"></span> Active & Ready
                    </p>
                </div>
            </div>
            
            <div class="ai-chat-messages" id="aiChatMessages">
                <div class="ai-message bot">
                    Hello! 👋 I am Rishi's AI Assistant. I'm fully synchronized with his portfolio to answer your questions about his full-stack capabilities, GDSC leadership, YouTube education, design services, or custom projects. How can I help you explore today?
                </div>
            </div>
            
            <!-- Quick prompt suggestion pills -->
            <div class="ai-suggestions" id="aiSuggestions">
                <div class="ai-pill" data-prompt="What projects have you built?">🚀 What projects have you built?</div>
                <div class="ai-pill" data-prompt="Tell me about your GDSC experience">👥 GDSC Tech Team Member</div>
                <div class="ai-pill" data-prompt="What services do you offer?">🎨 Services & Design Skills</div>
                <div class="ai-pill" data-prompt="How can I contact Rishi?">📞 How to get in touch?</div>
            </div>
            
            <div class="ai-chat-input-container">
                <input type="text" id="aiChatInput" placeholder="Ask me about his design services or tech stacks..." autocomplete="off">
                <button id="aiChatSend" aria-label="Send Message">
                    <i class="fas fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </section>
</body>

<script>
    (() => {
        // AI API integration configuration (matches backend layout)
        const BACKEND_URL = '<%= BACKEND_URL %>';
        
        const aiChatMessages = document.getElementById('aiChatMessages');
        const aiChatInput = document.getElementById('aiChatInput');
        const aiChatSend = document.getElementById('aiChatSend');
        const aiSuggestions = document.getElementById('aiSuggestions');
        
        let isWaitingForResponse = false;
        
        // Scroll to the bottom of the chat container
        const scrollToBottom = () => {
            requestAnimationFrame(() => {
                aiChatMessages.scrollTop = aiChatMessages.scrollHeight;
            });
        };
        
        // Helper to append a bot message
        const addBotMessage = (message) => {
            const messageElement = document.createElement('div');
            messageElement.classList.add('ai-message', 'bot');
            messageElement.innerHTML = message.replace(/\n/g, '<br>');
            aiChatMessages.appendChild(messageElement);
            scrollToBottom();
        };
        
        // Helper to append a user message
        const addUserMessage = (message) => {
            const messageElement = document.createElement('div');
            messageElement.classList.add('ai-message', 'user');
            messageElement.textContent = message;
            aiChatMessages.appendChild(messageElement);
            scrollToBottom();
        };

        // Helper to append an error message
        const addErrorMessage = (message) => {
            const messageElement = document.createElement('div');
            messageElement.classList.add('ai-message', 'error-msg');
            messageElement.innerHTML = message;
            aiChatMessages.appendChild(messageElement);
            scrollToBottom();
        };

        // Create and show typing indicator
        const showTypingIndicator = () => {
            const indicator = document.createElement('div');
            indicator.className = 'typing-indicator';
            indicator.id = 'aiTypingIndicator';
            indicator.innerHTML = '<span></span><span></span><span></span>';
            aiChatMessages.appendChild(indicator);
            scrollToBottom();
        };

        // Remove typing indicator
        const removeTypingIndicator = () => {
            const indicator = document.getElementById('aiTypingIndicator');
            if (indicator) {
                indicator.remove();
            }
        };
        
        // Handles communicating with the backend API
        const handleSendMessage = async (userInputText) => {
            if (isWaitingForResponse || !userInputText.trim()) return;

            const userText = userInputText.trim();
            addUserMessage(userText);
            
            // Set sending states
            isWaitingForResponse = true;
            aiChatInput.value = '';
            aiChatInput.disabled = true;
            aiChatSend.disabled = true;
            
            // Show typing dots
            showTypingIndicator();
            
            try {
                const response = await fetch(`${BACKEND_URL}/ai/chat`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ message: userText })
                });

                if (!response.ok) {
                    throw new Error('API server returned error status.');
                }

                const data = await response.json();
                
                removeTypingIndicator();
                
                if (data.success && data.reply) {
                    // Render formatting for markdown bold highlights if returned
                    let cleanReply = data.reply
                        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
                        .replace(/\*(.*?)\*/g, '<em>$1</em>');
                    addBotMessage(cleanReply);
                } else {
                    addErrorMessage("Hmm, I got an empty response from my system. Please try again!");
                }
            } catch (err) {
                console.error('Failed to communicate with AI endpoint:', err);
                removeTypingIndicator();
                addErrorMessage("<strong>Connection Offline:</strong> I've lost connection to my backend server. 🔌 Rishi might be updating my codebase, but you can try again shortly, or send him a direct message using the <strong>Get In Touch</strong> form below!");
            } finally {
                // Restore input elements
                isWaitingForResponse = false;
                aiChatInput.disabled = false;
                aiChatSend.disabled = false;
                aiChatInput.focus();
                scrollToBottom();
            }
        };
        
        // Trigger action on clicking send button
        aiChatSend.addEventListener('click', () => {
            const text = aiChatInput.value;
            if (text) {
                handleSendMessage(text);
            }
        });
        
        // Trigger action on hitting Enter key
        aiChatInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                const text = aiChatInput.value;
                if (text) {
                    handleSendMessage(text);
                }
            }
        });

        // Pill suggestion click listeners
        aiSuggestions.addEventListener('click', (e) => {
            const pill = e.target.closest('.ai-pill');
            if (pill && !isWaitingForResponse) {
                const promptText = pill.getAttribute('data-prompt');
                if (promptText) {
                    handleSendMessage(promptText);
                }
            }
        });
    })();
</script>
</html>
